# Copy to .env and adjust for your environment.
# Used by: alembic (make migrate / make rollback), make seed-* targets, make install.

DATABASE_URL=postgresql+asyncpg://pf:pf@localhost:5432/pf

# Pip index for make install / make reinstall.
# Uncomment when on corporative VPN to route through internal Artifactory.
# Off VPN: leave commented out — falls back to public PyPI automatically.
#PIP_ARTIFACTORY=https://pypi.ci.artifacts.corporative.com/artifactory/api/pypi/external-pypi/simple

# During migration coexistence (while other services still run their own
# postgres containers on 5432/5433), uncomment the lines below to shift pf-db
# to port 5434.  Remove once the old containers are stopped.
#PF_DB_PORT=5434
#DATABASE_URL=postgresql+asyncpg://pf:pf@localhost:5434/pf
